# ─────────────────────────────────────────────────────────────
# Copier ce fichier en .env :  cp .env.example .env
# Les valeurs ci-dessous sont des défauts de développement local.
# ─────────────────────────────────────────────────────────────

# PostgreSQL applicatif (service "db" du docker-compose)
DB_HOST=db
DB_NAME=gestionproduits
DB_USER=postgres
DB_PASSWORD=postgres

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=gestionproduits
KEYCLOAK_CLIENT_ID=gestionproduits-api

# URL publique de Keycloak (issuer présent dans le claim "iss" des tokens,
# telle que vue par le navigateur / le client qui obtient les tokens).
KEYCLOAK_PUBLIC_URL=http://localhost:8180
